# Blastradius — Environment Configuration Example
# Copy this file to .env and adjust values as needed.
# All services run fully locally — no paid cloud dependencies required.

# ---------------------------------------------------------------------------
# PostgreSQL Database
# ---------------------------------------------------------------------------
POSTGRES_DB=audittrail_db
POSTGRES_USER=audittrail_user
POSTGRES_PASSWORD=AuditTrail123!
# Host port the database is exposed on (container always uses 5432 internally)
POSTGRES_HOST_PORT=5051

# ---------------------------------------------------------------------------
# Backend (Spring Boot)
# ---------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/audittrail_db
SPRING_DATASOURCE_USERNAME=audittrail_user
SPRING_DATASOURCE_PASSWORD=AuditTrail123!
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Port the Spring Boot API listens on (and is exposed on the host)
SERVER_PORT=8051
SERVER_SERVLET_CONTEXT_PATH=/audittrail

# JWT secret used to sign auth tokens — change this in production!
SECURITY_JWT_SECRET=AuditTrailSecretKeyForJWTAuthentication2024ProductionSecureKey512BitsLong
SECURITY_JWT_EXPIRATION=86400000

# ---------------------------------------------------------------------------
# Frontend (React)
# ---------------------------------------------------------------------------
# URL the React app uses to call the backend API
REACT_APP_API_URL=http://localhost:8051/audittrail/api
# Host port the frontend (nginx) is exposed on
FRONTEND_HOST_PORT=8050

# ---------------------------------------------------------------------------
# Default seeded user (created on first run by AuthService/Liquibase seed)
# ---------------------------------------------------------------------------
DEFAULT_ADMIN_USERNAME=admin_user
DEFAULT_ADMIN_PASSWORD=AdminPass123!
